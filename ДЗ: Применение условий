sum_even = sum(i for i in range(1, 101) if i % 2 == 0)
print("Сумма всех четных чисел от 1 до 100:", sum_even)

odd_squares = [i ** 2 for i in range(1, 11) if i % 2 != 0]
print("Список квадратов нечетных чисел от 1 до 10:", odd_squares)

count = 1
num = 0
while num >= 0:
    num = int(input("Введите число (отрицательное число для завершения): "))
    if num >= 0:
        count += 1
print("Количество введенных чисел:", count)
