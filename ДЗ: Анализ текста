def symbols_del ():
    global text
    punctuations = '''!()—[]{};:'",<>./?@#$%^&*_№~'''
    for i in text:
        if i in punctuations:
            text = text.replace(i, "")


def count_of_words (words):
    return len(words)


def find_longest_word (words):
    longest_word = ""
    for word in words:
        if len(word) > len(longest_word):
            longest_word = word
    return longest_word


def count_of_vowels (text):
    letters = "аеёиоуыэюя"
    letters_count = 0
    for i in text:
        if i in letters:
                letters_count += 1
    return letters_count


def number_of_each_word (words):
    words_count = {}
    for i in words:
        words_count[i] = words_count.get(i, 0) + 1  # Увеличиваем счетчик слова
    return  words_count

text = input("Введите текст ").lower()
words = text.split()

symbols_del()
print("Кол-во слов: ", count_of_words(words))
print("Самое длинное слово: ", find_longest_word(text))
print("Кол-во гласных: ", count_of_vowels(text))
print("Кол-во каждого слова: ",number_of_each_word(words))

