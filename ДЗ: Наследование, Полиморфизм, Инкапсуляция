from abc import ABC, abstractmethod
import math


class Shape(ABC):
    @abstractmethod
    def area(self):
        pass


class Rectangle(Shape):
    def __init__(self, a, h):
        self.a = a
        self.h = h


    def area(self):
        print("Площадь треугольника: ", self.a/2 * self.h)


class Circle(Shape):
    def __init__(self, r):
        self.r = r


    def area(self):
        print("Площадь круга: ", math.pi * (self.r ** 2))


rectangle = Rectangle(4, 3)
circle = Circle(3)
rectangle.area()
circle.area()
